<?xml version="1.0"?>
<extension key="riveredge" type="module">
  <file>riveredge</file>
  <name>RiverEdge Theme</name>
  <description>A custom RiverLea child stream with dark mode improvements, mobile-responsive admin UI, accordion contact tabs, and full-width contact summary layout. Based on the Walbrook stream.</description>
  <license>MIT</license>
  <maintainer>
    <author>PB</author>
    <email>pb@example.com</email>
  </maintainer>
  <releaseDate>2026-03-23</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.0</ver>
  </compatibility>
  <requires>
    <ext>riverlea</ext>
  </requires>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/riveredge</namespace>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
  </mixins>
</extension>
